---
import ThemeToggle from '@/components/ui/ThemeToggle.astro';
import LangSwitch from '@/components/ui/LangSwitch.astro';
import { t, type Locale } from '@/i18n/utils';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const i18n = t(locale);
const base = '/portfolio';

const navLinks = [
  { href: `${base}/${locale}`, label: i18n.nav.home },
  { href: `${base}/${locale}/experience`, label: i18n.nav.experience },
  { href: `${base}/${locale}/projects`, label: i18n.nav.projects },
  { href: `${base}/${locale}/contact`, label: i18n.nav.contact },
];
---
<header class="fixed top-0 left-0 right-0 z-50 border-b border-[var(--border-color)] bg-[var(--bg-primary)]/80 backdrop-blur-md">
  <nav class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo / Name -->
      <a href={`${base}/${locale}`} class="text-lg font-bold text-[var(--text-primary)] hover:text-primary-500 transition-colors">
        G.R
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center gap-1">
        {navLinks.map(({ href, label }) => {
          const isActive = currentPath === href || (href !== `${base}/${locale}` && currentPath.startsWith(href));
          return (
            <a
              href={href}
              class:list={[
                'px-3 py-2 rounded-lg text-sm font-medium transition-colors duration-200',
                isActive
                  ? 'text-primary-600 dark:text-primary-400 bg-primary-50 dark:bg-primary-900/20'
                  : 'text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--bg-secondary)]',
              ]}
            >
              {label}
            </a>
          );
        })}
      </div>

      <!-- Actions -->
      <div class="flex items-center gap-2">
        <LangSwitch locale={locale} currentPath={currentPath} />
        <ThemeToggle />

        <!-- Mobile hamburger -->
        <button
          id="mobile-menu-btn"
          type="button"
          class="md:hidden p-2 rounded-lg hover:bg-[var(--bg-secondary)] transition-colors"
          aria-label="Open menu"
          aria-expanded="false"
        >
          <svg class="w-5 h-5 text-[var(--text-secondary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            <path id="close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <div class="flex flex-col gap-1 pt-2 border-t border-[var(--border-color)]">
        {navLinks.map(({ href, label }) => {
          const isActive = currentPath === href || (href !== `${base}/${locale}` && currentPath.startsWith(href));
          return (
            <a
              href={href}
              class:list={[
                'px-3 py-2 rounded-lg text-sm font-medium transition-colors duration-200',
                isActive
                  ? 'text-primary-600 dark:text-primary-400 bg-primary-50 dark:bg-primary-900/20'
                  : 'text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--bg-secondary)]',
              ]}
            >
              {label}
            </a>
          );
        })}
      </div>
    </div>
  </nav>
</header>

<script is:inline>
  function initMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const hamburger = document.getElementById('hamburger-icon');
    const close = document.getElementById('close-icon');

    btn?.addEventListener('click', () => {
      const isOpen = !menu?.classList.contains('hidden');
      menu?.classList.toggle('hidden');
      hamburger?.classList.toggle('hidden');
      close?.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  }
  initMobileMenu();
  document.addEventListener('astro:after-swap', initMobileMenu);
</script>