---
import Badge from '@/components/ui/Badge.astro';

interface Props {
  title: string;
  company?: string;
  description: string;
  image?: string;
  stack: string[];
  icon?: 'satellite' | 'aerospace' | 'agriculture' | 'gis' | 'erp' | 'urban' | 'admin';
}

const { title, company, description, image, stack, icon } = Astro.props;

const iconGradients: Record<string, string> = {
  satellite:   'from-indigo-100  to-blue-200   dark:from-indigo-900/40  dark:to-blue-800/30',
  aerospace:   'from-sky-100     to-cyan-200   dark:from-sky-900/40     dark:to-cyan-800/30',
  agriculture: 'from-green-100   to-emerald-200 dark:from-green-900/40  dark:to-emerald-800/30',
  gis:         'from-teal-100    to-green-200  dark:from-teal-900/40    dark:to-green-800/30',
  erp:         'from-amber-100   to-orange-200 dark:from-amber-900/40   dark:to-orange-800/30',
  urban:       'from-violet-100  to-purple-200 dark:from-violet-900/40  dark:to-purple-800/30',
  admin:       'from-slate-100   to-gray-200   dark:from-slate-900/40   dark:to-gray-800/30',
};

const iconColors: Record<string, string> = {
  satellite:   'text-indigo-400  dark:text-indigo-600',
  aerospace:   'text-sky-400     dark:text-sky-600',
  agriculture: 'text-green-400   dark:text-green-600',
  gis:         'text-teal-400    dark:text-teal-600',
  erp:         'text-amber-400   dark:text-amber-600',
  urban:       'text-violet-400  dark:text-violet-600',
  admin:       'text-slate-400   dark:text-slate-600',
};

const gradient = icon ? iconGradients[icon] : 'from-primary-100 to-primary-200 dark:from-primary-900/40 dark:to-primary-800/30';
const iconColor = icon ? iconColors[icon] : 'text-primary-300 dark:text-primary-700';
---
<div class="group h-full flex flex-col rounded-xl overflow-hidden bg-[var(--bg-card)] border border-[var(--border-color)]
            hover:border-primary-300 dark:hover:border-primary-700 transition-all duration-300
            hover:shadow-xl hover:shadow-primary-500/10 hover:-translate-y-1">
  <!-- Thumbnail -->
  {image ? (
    <div class="aspect-video overflow-hidden bg-[var(--bg-secondary)]">
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    </div>
  ) : (
    <div class:list={['aspect-video bg-gradient-to-br flex items-center justify-center', gradient]}>
      {icon === 'satellite' && (
        <svg class:list={['w-14 h-14', iconColor]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2">
          <!-- Corps central -->
          <rect x="9" y="9" width="6" height="6" rx="0.5" stroke-linecap="round" />
          <!-- Panneau solaire gauche -->
          <rect x="1.5" y="10.5" width="5.5" height="3" rx="0.3" stroke-linecap="round" />
          <!-- Bras gauche -->
          <line x1="7" y1="12" x2="9" y2="12" stroke-linecap="round" />
          <!-- Panneau solaire droit -->
          <rect x="17" y="10.5" width="5.5" height="3" rx="0.3" stroke-linecap="round" />
          <!-- Bras droit -->
          <line x1="15" y1="12" x2="17" y2="12" stroke-linecap="round" />
          <!-- Mât antenne -->
          <line x1="12" y1="9" x2="12" y2="6" stroke-linecap="round" />
          <!-- Parabole -->
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5.5 Q12 3.5 15 5.5" />
        </svg>
      )}
      {icon === 'aerospace' && (
        <svg class:list={['w-14 h-14', iconColor]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4c0 0-6 4-6 8h12c0-4-6-8-6-8z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 12H4l-1 4h3M18 12h2l1 4h-3" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 12v4l2 2 2-2v-4" />
        </svg>
      )}
      {icon === 'agriculture' && (
        <svg class:list={['w-14 h-14', iconColor]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 22V12" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 12C12 12 7 10 5 5c4 0 7 3 7 7z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 12C12 12 17 10 19 5c-4 0-7 3-7 7z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 17C12 17 9 15 8 12c2.5 0 4 2 4 5z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 17C12 17 15 15 16 12c-2.5 0-4 2-4 5z" />
        </svg>
      )}
      {icon === 'gis' && (
        <svg class:list={['w-14 h-14', iconColor]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2">
          <circle cx="12" cy="10" r="3" stroke-linecap="round" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 2C8.686 2 6 4.686 6 8c0 4.5 6 12 6 12s6-7.5 6-12c0-3.314-2.686-6-6-6z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 20h16" />
        </svg>
      )}
      {icon === 'erp' && (
        <svg class:list={['w-14 h-14', iconColor]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2">
          <!-- Façade -->
          <rect x="3" y="11" width="18" height="10" rx="1" stroke-linecap="round" />
          <!-- Auvent -->
          <path stroke-linecap="round" stroke-linejoin="round" d="M1 11l3-6h16l3 6" />
          <!-- Porte -->
          <rect x="10" y="15" width="4" height="6" rx="0.5" stroke-linecap="round" />
          <!-- Vitrine gauche -->
          <rect x="4" y="13" width="4" height="4" rx="0.5" stroke-linecap="round" />
          <!-- Vitrine droite -->
          <rect x="16" y="13" width="4" height="4" rx="0.5" stroke-linecap="round" />
        </svg>
      )}
      {icon === 'urban' && (
        <svg class:list={['w-14 h-14', iconColor]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2">
          <rect x="2" y="14" width="20" height="7" rx="1" stroke-linecap="round" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 14v-1a1 1 0 011-1h12a1 1 0 011 1v1" />
          <circle cx="7" cy="21" r="1.5" />
          <circle cx="17" cy="21" r="1.5" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 13V9M18 13V9M9 13v-3M15 13v-3M12 13V7" />
        </svg>
      )}
      {icon === 'admin' && (
        <svg class:list={['w-14 h-14', iconColor]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6M9 16h4M7 4H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V8l-5-4H7z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M14 4v4h4" />
        </svg>
      )}
      {!icon && (
        <svg class:list={['w-12 h-12', iconColor]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
      )}
    </div>
  )}

  <!-- Content -->
  <div class="p-5 flex flex-col flex-1">
    <h3 class="text-lg font-bold text-[var(--text-primary)] transition-colors">
      {title}
    </h3>
    {company && (
      <p class="text-sm text-primary-600 dark:text-primary-400 font-medium mt-0.5">
        {company}
      </p>
    )}
    <p class="mt-2 text-sm text-[var(--text-secondary)] leading-relaxed">
      {description}
    </p>

    <!-- Body (rendered markdown) -->
    <div class="mt-3 text-sm text-[var(--text-secondary)] leading-relaxed prose prose-sm dark:prose-invert max-w-none
                prose-ul:mt-1 prose-ul:space-y-0.5 prose-li:my-0 prose-headings:text-xs prose-headings:font-semibold
                prose-headings:text-[var(--text-muted)] prose-headings:uppercase prose-headings:tracking-wide prose-headings:mt-3">
      <slot name="body" />
    </div>

    <!-- Stack -->
    <div class="mt-auto pt-4 flex flex-wrap gap-1.5">
      {stack.map((tech) => (
        <Badge text={tech} variant="neutral" />
      ))}
    </div>
  </div>
</div>
