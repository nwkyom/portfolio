---
import Badge from '@/components/ui/Badge.astro';
import FadeIn from '@/components/animations/FadeIn.astro';
import { t, type Locale } from '@/i18n/utils';

interface ExperienceEntry {
  company: string;
  project?: string;
  role: string;
  startDate: string;
  endDate: string;
  location: string;
  description: string;
  stack: string[];
  body: string;
}

interface Props {
  locale: Locale;
  entries: ExperienceEntry[];
}

const { locale, entries } = Astro.props;
const i18n = t(locale);
---
<div class="relative">
  <!-- Vertical line -->
  <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-0.5 bg-gradient-to-b from-primary-500 via-accent-500 to-primary-500 transform md:-translate-x-px"></div>

  <div class="space-y-12">
    {entries.map((entry, index) => {
      const isLeft = index % 2 === 0;
      return (
        <FadeIn delay={index * 0.15} y={40}>
          <div class:list={[
            'relative flex items-start gap-8',
            'pl-12 md:pl-0',
            isLeft ? 'md:flex-row' : 'md:flex-row-reverse',
          ]}>
            <!-- Dot on timeline -->
            <div class="absolute left-4 md:left-1/2 w-3 h-3 rounded-full bg-primary-500 border-2 border-[var(--bg-primary)] transform -translate-x-1.5 md:-translate-x-1.5 mt-6 z-10 shadow-lg shadow-primary-500/30"></div>

            <!-- Date badge (desktop only, opposite side) -->
            <div class:list={[
              'hidden md:flex md:w-1/2 items-start mt-5',
              isLeft ? 'justify-end pr-12' : 'justify-start pl-12',
            ]}>
              <span class="text-sm font-medium text-primary-600 dark:text-primary-400 bg-primary-50 dark:bg-primary-900/20 px-3 py-1 rounded-full">
                {entry.startDate} — {entry.endDate}
              </span>
            </div>

            <!-- Card -->
            <div class:list={[
              'md:w-1/2',
              isLeft ? 'md:pr-12' : 'md:pl-12',
            ]}>
              <div class="p-6 rounded-xl bg-[var(--bg-card)] border border-[var(--border-color)]
                          hover:border-primary-300 dark:hover:border-primary-700 transition-all duration-300
                          hover:shadow-lg hover:shadow-primary-500/5">
                <!-- Mobile date -->
                <span class="md:hidden text-xs font-medium text-primary-600 dark:text-primary-400 bg-primary-50 dark:bg-primary-900/20 px-2 py-0.5 rounded-full">
                  {entry.startDate} — {entry.endDate}
                </span>

                <h3 class="text-lg font-bold text-[var(--text-primary)] mt-2 md:mt-0">
                  {entry.role}
                </h3>
                <p class="text-sm text-primary-600 dark:text-primary-400 font-medium">
                  {entry.company}
                  {entry.project && <span class="text-[var(--text-muted)]"> — {entry.project}</span>}
                </p>
                <p class="text-xs text-[var(--text-muted)] mt-1">{entry.location}</p>

                <p class="mt-3 text-sm text-[var(--text-secondary)] leading-relaxed">
                  {entry.description}
                </p>

                <!-- Tech stack -->
                <div class="mt-4">
                  <p class="text-xs font-medium text-[var(--text-muted)] mb-2">{i18n.experience.stack}</p>
                  <div class="flex flex-wrap gap-1.5">
                    {entry.stack.map((tech) => (
                      <Badge text={tech} variant="neutral" />
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </FadeIn>
      );
    })}
  </div>
</div>
