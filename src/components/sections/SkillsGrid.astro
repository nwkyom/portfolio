---
import { skillCategories } from '@/data/skills';
import Badge from '@/components/ui/Badge.astro';
import FadeIn from '@/components/animations/FadeIn.astro';
import { type Locale } from '@/i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---
<section class="py-16 sm:py-24 bg-[var(--bg-secondary)]">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <FadeIn>
      <h2 class="text-3xl font-bold text-center mb-12 text-[var(--text-primary)]">
        {locale === 'fr' ? 'Compétences' : 'Skills'}
      </h2>
    </FadeIn>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {skillCategories.map((category, index) => (
        <FadeIn delay={index * 0.1}>
          <div class="p-6 rounded-xl bg-[var(--bg-card)] border border-[var(--border-color)]
                      hover:border-primary-300 dark:hover:border-primary-700 transition-colors duration-200
                      hover:shadow-lg hover:shadow-primary-500/5">
            <h3 class="text-lg font-semibold text-[var(--text-primary)] mb-4">
              {category.label[locale]}
            </h3>
            <div class="flex flex-wrap gap-2">
              {category.skills.map((skill) => (
                <Badge text={skill.name} variant="primary" />
              ))}
            </div>
          </div>
        </FadeIn>
      ))}
    </div>
  </div>
</section>
