---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Timeline from '@/components/sections/Timeline.astro';
import FadeIn from '@/components/animations/FadeIn.astro';
import { getCollection } from 'astro:content';
import { t } from '@/i18n/utils';
import { personal } from '@/data/personal';

const i18n = t('fr');

const allExperiences = await getCollection('experience');
const experiences = allExperiences
  .filter((e) => e.data.locale === 'fr')
  .sort((a, b) => a.data.order - b.data.order)
  .map((e) => ({ ...e.data, body: e.body || '' }));
---
<BaseLayout
  title={`${i18n.experience.title} — ${personal.name}`}
  description={i18n.experience.subtitle}
  locale="fr"
>
  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <FadeIn>
        <div class="text-center mb-16">
          <h1 class="text-3xl sm:text-4xl font-bold text-[var(--text-primary)]">
            {i18n.experience.title}
          </h1>
          <p class="mt-4 text-lg text-[var(--text-secondary)] max-w-2xl mx-auto">
            {i18n.experience.subtitle}
          </p>
        </div>
      </FadeIn>

      <Timeline locale="fr" entries={experiences} />
    </div>
  </section>
</BaseLayout>
